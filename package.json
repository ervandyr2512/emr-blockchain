{
  "name": "emr-blockchain",
  "version": "1.0.0",
  "description": "Blockchain-Based Electronic Medical Record System — Ervandy Rangganata",
  "private": true,
  "scripts": {
    "build":        "cd frontend && npm install && npm run build",
    "dev":          "cd frontend && npm run dev",
    "start":        "cd frontend && npm start",
    "compile":      "hardhat compile",
    "test":         "hardhat test",
    "node":         "hardhat node",
    "deploy:local": "hardhat run scripts/deploy.js --network localhost"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.22.0"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  }
}

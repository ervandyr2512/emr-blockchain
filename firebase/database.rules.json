{
  "rules": {
    // ── Users ─────────────────────────────────────────────────────────────
    "users": {
      "$uid": {
        // A user can read/write their own profile
        ".read":  "auth != null && (auth.uid === $uid)",
        ".write": "auth != null && (auth.uid === $uid)",
        // Admin can read all profiles
        ".read":  "auth != null"
      }
    },

    // ── Patients ──────────────────────────────────────────────────────────
    "patients": {
      ".read":  "auth != null",
      ".write": "auth != null",
      "$emrId": {
        ".validate": "newData.hasChildren(['emrId','uid','firstName','lastName','createdAt'])"
      }
    },

    // ── SOAP Notes ────────────────────────────────────────────────────────
    "soap_notes": {
      ".read":  "auth != null",
      "$emrId": {
        ".write": "auth != null",
        "$noteId": {
          ".validate": "newData.hasChildren(['emrId','nurseUid','subjective','objective','createdAt'])"
        }
      }
    },

    // ── Doctor Notes ──────────────────────────────────────────────────────
    "doctor_notes": {
      ".read":  "auth != null",
      "$emrId": {
        ".write": "auth != null",
        "$noteId": {
          ".validate": "newData.hasChildren(['emrId','doctorUid','workingDiagnosis','createdAt'])"
        }
      }
    },

    // ── Prescriptions ─────────────────────────────────────────────────────
    "prescriptions": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    // ── Counters (EMR ID generator) ────────────────────────────────────────
    "counters": {
      ".read":  "auth != null",
      ".write": "auth != null"
    }
  }
}

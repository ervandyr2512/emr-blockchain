{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "patients": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["uid", "status"],
      "$emrId": {
        ".validate": "newData.hasChildren(['emrId','uid','firstName','lastName','createdAt'])"
      }
    },
    "soap_notes": {
      ".read": "auth != null",
      "$emrId": {
        ".write": "auth != null",
        "$noteId": {
          ".validate": "newData.hasChildren(['emrId','nurseUid','subjective','objective','createdAt'])"
        }
      }
    },
    "doctor_notes": {
      ".read": "auth != null",
      "$emrId": {
        ".write": "auth != null",
        "$noteId": {
          ".validate": "newData.hasChildren(['emrId','doctorUid','workingDiagnosis','createdAt'])"
        }
      }
    },
    "prescriptions": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "counters": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}

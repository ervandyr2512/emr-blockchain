# Root .env.example — copy to .env and fill in values

# Hardhat / blockchain
PRIVATE_KEY=0xYOUR_METAMASK_PRIVATE_KEY_HERE
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Backend (see backend/.env.example for more)
CONTRACT_ADDRESS=0xDEPLOYED_CONTRACT_ADDRESS_HERE
RPC_URL=http://127.0.0.1:8545

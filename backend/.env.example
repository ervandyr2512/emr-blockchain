# Backend environment — copy to .env and fill in values

# Ethereum RPC (local Hardhat node)
RPC_URL=http://127.0.0.1:8545

# Private key of the backend "operator" account (Hardhat account #0 by default)
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Deployed EMR contract address (set after running deploy.js)
CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# Port for the Express API
PORT=3001

# Off-chain data directory (simulated IPFS)
DATA_DIR=./data/records
